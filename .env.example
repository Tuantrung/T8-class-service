# ── Database ──────────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/classservice
DB_USERNAME=classservice
DB_PASSWORD=classservice

# ── JWT ───────────────────────────────────────────────────────────────────────
# IMPORTANT: Change to a strong random secret (>= 32 chars) in production!
JWT_SECRET=dev-secret-key-32-characters-min!
JWT_EXPIRY_HOURS=8

# ── Application ───────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev
CORS_ALLOWED_ORIGINS=http://localhost:5173
PDF_EXPORT_DIR=/tmp/pdf-exports
